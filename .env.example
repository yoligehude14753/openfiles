# ============================================
# OpenFiles Configuration
# ============================================

# --- LLM Provider ---
# Options: ollama (recommended, local), openai, claude, kimi, openai-compatible
LLM_PROVIDER=ollama

# --- Ollama (Local LLM - recommended, no API key needed) ---
# Install: https://ollama.com
# Then: ollama pull llama3.2 && ollama pull nomic-embed-text
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# --- Embedding Provider ---
# Options: ollama (recommended), openai, local (requires torch)
EMBEDDING_PROVIDER=ollama

# --- OpenAI-compatible API (optional, for cloud models) ---
# Works with any OpenAI-compatible endpoint (OpenRouter, etc.)
OPENAI_COMPATIBLE_API_KEY=
OPENAI_COMPATIBLE_BASE_URL=
OPENAI_COMPATIBLE_MODEL=gpt-4o-mini
OPENAI_COMPATIBLE_EMBEDDING_MODEL=text-embedding-3-small

# --- Direct OpenAI / Anthropic / Kimi (optional) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
KIMI_API_KEY=

# --- Database ---
DATABASE_PATH=./data/db/files.db

# --- Indexing ---
SCAN_DIRECTORIES=~/Documents,~/Desktop,~/Downloads
EXCLUDE_PATTERNS=.git,.DS_Store,node_modules,__pycache__,venv,.venv
MAX_FILE_SIZE_MB=100

# --- Cost Controls ---
DAILY_BUDGET_USD=10.0
MONTHLY_BUDGET_USD=100.0

# --- Privacy ---
PRIVACY_MODE=false
BLACKLIST_DIRS=.ssh,.gnupg

# --- Performance ---
MAX_CONCURRENT_LLM=3
MAX_CONCURRENT_EMBEDDING=5
CHUNK_SIZE=4000

# --- Web Server ---
WEB_HOST=0.0.0.0
WEB_PORT=8000

# --- Chat ---
CHAT_MAX_HISTORY=20
CHAT_MAX_CONTEXT_CHUNKS=5
