{
  "identifier": "default",
  "description": "Default capabilities for ChatFiles",
  "windows": ["spotlight", "settings"],
  "permissions": [
    "core:default",
    "shell:allow-spawn",
    "shell:allow-execute",
    "shell:allow-open",
    "global-shortcut:allow-register",
    "global-shortcut:allow-unregister",
    "global-shortcut:allow-is-registered"
  ]
}
